# Copie ces variables dans Vercel > Project > Settings > Environment Variables.
# Ne mets jamais ces valeurs dans GitHub.

NEXT_PUBLIC_SITE_URL=https://resellscore.vercel.app

# Supabase reel
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin proprietaire
ADMIN_OWNER_EMAIL=jayko9045@gmail.com

# Paiement
# manual = paiement PayPal facture/preuve puis activation admin
# paypal = abonnement automatique PayPal Live
PAYMENT_MODE=manual

# IA
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# PayPal LIVE, pas sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_PLAN_STARTER_ID=
PAYPAL_PLAN_PRO_ID=
PAYPAL_PLAN_ELITE_ID=
PAYPAL_WEBHOOK_ID=
